# Copy this to .env.test.local and fill in the values.
# NEVER commit .env.test.local — it contains the service role key.

# Same as .env.local — inherited automatically
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Required for Playwright E2E auth setup (Supabase dashboard → Settings → API → service_role)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Email address used for the E2E test user (can be anything — never receives real email)
TEST_USER_EMAIL=buildbuddy-e2e@test.local
